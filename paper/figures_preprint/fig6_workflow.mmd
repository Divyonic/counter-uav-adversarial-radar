    D["Design attacks<br/><span style='font-size:12px;color:#555'>against used features</span>"]
    E["Run attacks"]
    F["Report attack results<br/>+ attribution<br/>that justified the design"]

    G["Traditional approach:<br/><span style='font-size:12px;color:#555'>design attacks against<br/>assumed physics</span>"]
    H["Run attacks"]
    I["Null result<br/>(uninterpretable)"]

    A --> B --> C
    C -->|identified| D --> E --> F
    G -.-> H -.-> I

    classDef good fill:#dcfce7,stroke:#15803d,stroke-width:1.5px,color:#14532d
    classDef bad fill:#fee2e2,stroke:#b91c1c,stroke-width:1.5px,color:#7f1d1d
    classDef highlight fill:#fef3c7,stroke:#d97706,stroke-width:1.5px,color:#78350f
    class F good
    class I bad
    class B highlight

flowchart LR
    A["FMCW chirp<br/><span style='font-size:12px;color:#555'>9.5 GHz · 1 GHz BW</span>"]
    B["Target echo<br/><span style='font-size:12px;color:#555'>micro-Doppler</span>"]
    C["Beat signal<br/><span style='font-size:12px;color:#555'>128 × 128</span>"]
    D["STFT spectrogram<br/><span style='font-size:12px;color:#555'>128 × 128 · 10 frames</span>"]
    E["BFP extractor<br/><span style='font-size:12px;color:#555'>autocorr → 3-vec</span>"]
    F["CNN<br/><span style='font-size:12px;color:#555'>4 conv blocks</span>"]
    G["LSTM<br/><span style='font-size:12px;color:#555'>10 × 64 units</span>"]
    H["Concat + Softmax"]
    I{"Drone<br/>Bird<br/>Fixed-wing UAV<br/>Aircraft"}

    A --> B --> C
    C --> D --> F --> G --> H
    C --> E --> H
    H --> I

    classDef physics fill:#fef3c7,stroke:#d97706,stroke-width:1.5px,color:#78350f
    classDef head fill:#dbeafe,stroke:#1d4ed8,stroke-width:1.5px,color:#1e3a8a
    classDef output fill:#dcfce7,stroke:#15803d,stroke-width:1.5px,color:#14532d
    class E physics
    class H head
    class I output
